# OPTIONAL - only needed when you want to monitor your own software
# OPENROUTER_API_KEY=sk-or-v1-...

# OPTIONAL - direct provider access
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# OPTIONAL - alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@geostorm.io

# OPTIONAL
# SECRET_KEY=generate-random-string

# OPTIONAL - structured logging to Logfire cloud
# Console logging works without this. Set the token to also send logs to Logfire cloud.
# LOGFIRE_TOKEN=
