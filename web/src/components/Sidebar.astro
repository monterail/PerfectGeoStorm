---
import { SidebarProjects } from "./islands/SidebarProjects"

const currentPath = Astro.url.pathname
---

<aside class="hidden w-64 shrink-0 border-r bg-background md:block">
	<div class="flex h-full flex-col">
		<div class="flex items-center justify-between border-b px-4 py-3">
			<h2 class="text-sm font-semibold">Projects</h2>
			<a
				href="/setup"
				class="inline-flex h-7 items-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground shadow hover:bg-primary/90"
			>
				New
			</a>
		</div>
		<nav class="flex-1 overflow-y-auto p-2">
			<SidebarProjects client:load currentPath={currentPath} />
		</nav>
	</div>
</aside>
